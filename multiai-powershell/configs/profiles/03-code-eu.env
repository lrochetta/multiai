PROFILE_ID=code-eu
SHORTCUT=ceu
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=Code EU (Requesty RGPD)
DESCRIPTION=Requesty EU Frankfurt — conforme RGPD, fallback automatique
ORDER=3
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=REQUESTY_API_KEY
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-eu
ANTHROPIC_BASE_URL=https://router.eu.requesty.ai
ANTHROPIC_AUTH_TOKEN=%REQUESTY_API_KEY%
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek/deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=google/gemini-3.5-flash
ANTHROPIC_API_KEY=
REQUESTY_API_KEY=PASTE_REQUESTY_API_KEY_HERE
