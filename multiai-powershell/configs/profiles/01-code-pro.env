PROFILE_ID=code-pro
SHORTCUT=cp
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=Code Pro (premium)
DESCRIPTION=Modele premium — DeepSeek V4 Pro 1M + effort max
ORDER=1
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=ANTHROPIC_AUTH_TOKEN
