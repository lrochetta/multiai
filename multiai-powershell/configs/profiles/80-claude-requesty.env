PROFILE_ID=claude-requesty
SHORTCUT=req-cc
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=Claude Code via Requesty
DESCRIPTION=Claude Code via gateway Requesty (Anthropic-compatible)
ORDER=80
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=REQUESTY_API_KEY
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-requesty
REQUESTY_API_KEY=PASTE_REQUESTY_API_KEY_HERE
ANTHROPIC_BASE_URL=https://router.requesty.ai
ANTHROPIC_AUTH_TOKEN=%REQUESTY_API_KEY%
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_DEFAULT_OPUS_MODEL=anthropic/claude-opus-4-8
ANTHROPIC_DEFAULT_SONNET_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=openai/gpt-4o-mini
ANTHROPIC_API_KEY=
