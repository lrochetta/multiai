PROFILE_ID=claude-fusion
SHORTCUT=or-fusion
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=OpenRouter Fusion (Multi-Model)
DESCRIPTION=Panel d'experts multi-modeles - le meilleur modele choisi automatiquement
ORDER=5
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=OPENROUTER_API_KEY
OPENROUTER_API_KEY=PASTE_OPENROUTER_API_KEY_HERE
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_MODEL=openrouter/fusion
ANTHROPIC_DEFAULT_OPUS_MODEL=openrouter/fusion
ANTHROPIC_DEFAULT_SONNET_MODEL=openrouter/fusion
ANTHROPIC_DEFAULT_HAIKU_MODEL=openrouter/fusion
ANTHROPIC_AUTH_TOKEN=%OPENROUTER_API_KEY%
ANTHROPIC_API_KEY=
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-fusion
