PROFILE_ID=opencode-siliconflow
SHORTCUT=oc-siliconflow
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode via SiliconFlow
DESCRIPTION=OpenCode avec modeles open-source via SiliconFlow
ORDER=243
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=SILICONFLOW_API_KEY
SILICONFLOW_API_KEY=PASTE_SILICONFLOW_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"siliconflow/default","small_model":"siliconflow/default","provider":{"siliconflow":{"npm":"@ai-sdk/openai-compatible","name":"SiliconFlow","options":{"baseURL":"https://api.siliconflow.cn/v1","apiKey":"{env:SILICONFLOW_API_KEY}","timeout":600000,"chunkTimeout":60000}}},"share":"manual"}
