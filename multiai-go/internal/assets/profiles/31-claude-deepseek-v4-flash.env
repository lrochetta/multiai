PROFILE_ID=claude-deepseek-v4-flash
SHORTCUT=dsf
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=DeepSeek V4 Flash
DESCRIPTION=DeepSeek rapide/economique via endpoint Anthropic-compatible.
ORDER=41
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=ANTHROPIC_AUTH_TOKEN
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-deepseek-v4flash
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=PASTE_DEEPSEEK_API_KEY_HERE
ANTHROPIC_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_AUTO_COMPACT_WINDOW=1000000
API_TIMEOUT_MS=3000000
