PROFILE_ID=opencode-xiaomi-mimo
SHORTCUT=ocmimo
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode Xiaomi MiMo
DESCRIPTION=OpenCode avec Xiaomi MiMo (endpoint OpenAI-compatible)
ORDER=244
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=MIMO_API_KEY
MIMO_API_KEY=PASTE_MIMO_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"mimo/mimo-auto","small_model":"mimo/mimo-auto","provider":{"mimo":{"npm":"@ai-sdk/openai-compatible","name":"MiMo","options":{"baseURL":"https://api.xiaomimimo.com/v1","apiKey":"{env:MIMO_API_KEY}","timeout":600000,"chunkTimeout":60000},"models":{"mimo-auto":{"name":"MiMo Auto 1M"}}}},"share":"manual"}
