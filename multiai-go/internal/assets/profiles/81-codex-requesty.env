PROFILE_ID=codex-requesty
SHORTCUT=req-codex
TOOL=codex
TOOL_LABEL=Codex CLI
DISPLAY_NAME=Codex via Requesty
DESCRIPTION=Codex via gateway Requesty (fallback, cache, EU). Codex 2026 ignore OPENAI_BASE_URL: provider injecte par flags -c (API Responses Requesty, verifiee); modele openai/gpt-5.5.
ORDER=112
COMMAND=codex
ARGS=-c model_provider=requesty -c model=openai/gpt-5.5 -c model_providers.requesty.name=Requesty -c model_providers.requesty.base_url=https://router.requesty.ai/v1 -c model_providers.requesty.env_key=REQUESTY_API_KEY -c model_providers.requesty.wire_api=responses
CLEAR_ENV=true
REQUIRED_SECRETS=REQUESTY_API_KEY
REQUESTY_API_KEY=PASTE_REQUESTY_API_KEY_HERE
OPENAI_API_KEY=%REQUESTY_API_KEY%
OPENAI_BASE_URL=https://router.requesty.ai/v1
