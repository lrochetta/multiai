PROFILE_ID=claude-xiaomi-mimo
SHORTCUT=mimo
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=Xiaomi MiMo V2.5 Pro
DESCRIPTION=MiMo V2.5 Pro via endpoint Anthropic-compatible
ORDER=78
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=MIMO_API_KEY
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-mimo
MIMO_API_KEY=PASTE_MIMO_API_KEY_HERE
ANTHROPIC_BASE_URL=https://api.xiaomimimo.com/anthropic
ANTHROPIC_AUTH_TOKEN=%MIMO_API_KEY%
ANTHROPIC_MODEL=mimo-auto
ANTHROPIC_DEFAULT_OPUS_MODEL=mimo-auto
ANTHROPIC_DEFAULT_SONNET_MODEL=mimo-auto
ANTHROPIC_DEFAULT_HAIKU_MODEL=mimo-auto
CLAUDE_CODE_AUTO_COMPACT_WINDOW=1000000
API_TIMEOUT_MS=3000000
CLAUDE_CODE_EFFORT_LEVEL=max
