PROFILE_ID=claude-litellm
SHORTCUT=litellm
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=Claude Code via LiteLLM proxy
DESCRIPTION=LiteLLM proxy local (port 4000) — routage multi-modele
ORDER=83
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=LITELLM_API_KEY
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-litellm
LITELLM_API_KEY=PASTE_LITELLM_PROXY_KEY_HERE
ANTHROPIC_BASE_URL=http://localhost:4000
ANTHROPIC_AUTH_TOKEN=%LITELLM_API_KEY%
ANTHROPIC_MODEL=openai/gpt-4o
ANTHROPIC_DEFAULT_OPUS_MODEL=anthropic/claude-opus-4-8
ANTHROPIC_DEFAULT_SONNET_MODEL=openai/gpt-4o
ANTHROPIC_DEFAULT_HAIKU_MODEL=openai/gpt-4o-mini
ANTHROPIC_API_KEY=
