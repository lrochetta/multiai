PROFILE_ID=codex-siliconflow
SHORTCUT=codex-sf
TOOL=codex
TOOL_LABEL=Codex CLI
DISPLAY_NAME=Codex via SiliconFlow
DESCRIPTION=[CASSE Codex 2026] SiliconFlow ne sert pas l'API Responses (404 verifie 2026-07-20) et Codex a supprime chat/completions. Utiliser oc-siliconflow (OpenCode) ou attendre un pont generique.
NOTES=Codex 2026 ignore aussi OPENAI_BASE_URL et retombe silencieusement sur le compte OpenAI connecte.
ORDER=111
COMMAND=codex
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=SILICONFLOW_API_KEY
SILICONFLOW_API_KEY=PASTE_SILICONFLOW_API_KEY_HERE
OPENAI_API_KEY=%SILICONFLOW_API_KEY%
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
