PROFILE_ID=claude-zai-glm52
SHORTCUT=cg
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=Z.ai GLM-5.2 Coding Plan
DESCRIPTION=GLM-5.2 via endpoint Anthropic-compatible Z.ai.
ORDER=30
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=ANTHROPIC_AUTH_TOKEN
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-zai-glm52
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=PASTE_ZAI_CODING_PLAN_KEY_HERE
ANTHROPIC_MODEL=glm-5.2[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.7
CLAUDE_CODE_SUBAGENT_MODEL=glm-4.7
CLAUDE_CODE_AUTO_COMPACT_WINDOW=1000000
API_TIMEOUT_MS=3000000
CLAUDE_CODE_EFFORT_LEVEL=max
