PROFILE_ID=opencode-nvidia
SHORTCUT=ocnvidia
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode NVIDIA NIM gratuit (GLM-5.2 + 9 modeles)
DESCRIPTION=Acces direct build.nvidia.com (100% gratuit, ~40 req/min): GLM-5.2, DeepSeek V4, Kimi K2.6, MiniMax M3, Qwen 3.5, GPT-OSS, Nemotron, Mistral Large 3.
ORDER=246
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=NVIDIA_API_KEY
NVIDIA_API_KEY=PASTE_NVIDIA_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"nvidia/z-ai/glm-5.2","small_model":"nvidia/deepseek-ai/deepseek-v4-flash","provider":{"nvidia":{"npm":"@ai-sdk/openai-compatible","name":"NVIDIA NIM (gratuit)","options":{"baseURL":"https://integrate.api.nvidia.com/v1","apiKey":"{env:NVIDIA_API_KEY}","timeout":600000,"chunkTimeout":120000},"models":{"z-ai/glm-5.2":{"name":"GLM 5.2 (1M ctx)","limit":{"context":1000000,"output":32768}},"deepseek-ai/deepseek-v4-pro":{"name":"DeepSeek V4 Pro"},"deepseek-ai/deepseek-v4-flash":{"name":"DeepSeek V4 Flash"},"moonshotai/kimi-k2.6":{"name":"Kimi K2.6"},"minimaxai/minimax-m3":{"name":"MiniMax M3"},"qwen/qwen3.5-397b-a17b":{"name":"Qwen 3.5 397B"},"qwen/qwen3-next-80b-a3b-instruct":{"name":"Qwen3 Next 80B"},"openai/gpt-oss-120b":{"name":"GPT-OSS 120B"},"nvidia/nemotron-3-super-120b-a12b":{"name":"Nemotron 3 Super 120B"},"mistralai/mistral-large-3-675b-instruct-2512":{"name":"Mistral Large 3"}}}},"share":"manual"}
