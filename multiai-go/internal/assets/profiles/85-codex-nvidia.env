PROFILE_ID=codex-nvidia
SHORTCUT=codex-nv
TOOL=codex
TOOL_LABEL=Codex CLI
DISPLAY_NAME=Codex NVIDIA GLM-5.2 gratuit (pont LiteLLM)
DESCRIPTION=GLM-5.2 gratuit via build.nvidia.com. Codex 2026 ne supporte plus chat/completions: pont local LiteLLM port 4000 obligatoire (guide: multiai-go/docs/guide/nvidia.md).
ORDER=113
COMMAND=codex
ARGS=-c model_provider=nvidia -c model=z-ai/glm-5.2 -c model_providers.nvidia.name=NVIDIA -c model_providers.nvidia.base_url=http://localhost:4000 -c model_providers.nvidia.env_key=NVIDIA_API_KEY -c model_providers.nvidia.wire_api=responses
CLEAR_ENV=true
REQUIRED_SECRETS=NVIDIA_API_KEY
NVIDIA_API_KEY=PASTE_NVIDIA_API_KEY_HERE
