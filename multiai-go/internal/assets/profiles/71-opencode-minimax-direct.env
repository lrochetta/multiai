PROFILE_ID=opencode-minimax-direct
SHORTCUT=ocmini
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode MiniMax M3 direct
DESCRIPTION=OpenCode avec MiniMax M3 (endpoint OpenAI-compatible direct)
ORDER=240
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=MINIMAX_API_KEY
MINIMAX_API_KEY=PASTE_MINIMAX_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"minimax/minimax-m3","small_model":"minimax/minimax-m3","provider":{"minimax":{"npm":"@ai-sdk/openai-compatible","name":"MiniMax","options":{"baseURL":"https://api.minimax.io/v1","apiKey":"{env:MINIMAX_API_KEY}","timeout":600000,"chunkTimeout":60000},"models":{"minimax-m3":{"name":"MiniMax M3 1M"}}}},"share":"manual"}
