PROFILE_ID=opencode-anthropic-claude
SHORTCUT=ocanthropic
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode Anthropic Claude
DESCRIPTION=OpenCode avec Anthropic. Ajuste les model ids selon ton acces exact.
ORDER=211
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=PASTE_ANTHROPIC_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"anthropic/claude-opus-4-8","small_model":"anthropic/claude-haiku-4-5","provider":{"anthropic":{"options":{"apiKey":"{env:ANTHROPIC_API_KEY}","timeout":600000,"chunkTimeout":60000,"setCacheKey":true}}},"share":"manual"}
