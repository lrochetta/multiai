PROFILE_ID=opencode-kimi-openrouter
SHORTCUT=ockimi
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode Kimi via OpenRouter
DESCRIPTION=Template Kimi/Moonshot via OpenRouter. Remplace le model id par celui que tu veux utiliser.
ORDER=231
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=OPENROUTER_API_KEY
OPENROUTER_API_KEY=PASTE_OPENROUTER_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"openrouter/moonshotai/kimi-k2","small_model":"openrouter/moonshotai/kimi-k2","provider":{"openrouter":{"options":{"apiKey":"{env:OPENROUTER_API_KEY}","timeout":600000,"chunkTimeout":60000}}},"share":"manual"}
