PROFILE_ID=opencode-deepseek-v4-pro
SHORTCUT=ocdeepseek
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode DeepSeek V4 Pro
DESCRIPTION=OpenCode avec provider custom DeepSeek OpenAI-compatible. Ajuste le model id si ton compte impose un autre nom.
ORDER=220
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=DEEPSEEK_API_KEY
DEEPSEEK_API_KEY=PASTE_DEEPSEEK_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"deepseek/deepseek-v4-pro[1m]","small_model":"deepseek/deepseek-v4-flash","provider":{"deepseek":{"npm":"@ai-sdk/openai-compatible","name":"DeepSeek","options":{"baseURL":"https://api.deepseek.com/v1","apiKey":"{env:DEEPSEEK_API_KEY}","timeout":600000,"chunkTimeout":60000},"models":{"deepseek-v4-pro[1m]":{"name":"DeepSeek V4 Pro 1M"},"deepseek-v4-flash":{"name":"DeepSeek V4 Flash"}}}},"share":"manual"}
