PROFILE_ID=opencode-qwen-openrouter
SHORTCUT=ocqwen
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode Qwen via OpenRouter
DESCRIPTION=Template Qwen via OpenRouter. Remplace le model id par celui que tu veux utiliser.
ORDER=230
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=OPENROUTER_API_KEY
OPENROUTER_API_KEY=PASTE_OPENROUTER_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"openrouter/qwen/qwen3-coder","small_model":"openrouter/qwen/qwen3-coder:free","provider":{"openrouter":{"options":{"apiKey":"{env:OPENROUTER_API_KEY}","timeout":600000,"chunkTimeout":60000}}},"share":"manual"}
