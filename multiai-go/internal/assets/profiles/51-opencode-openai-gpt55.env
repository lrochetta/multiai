PROFILE_ID=opencode-openai-gpt55
SHORTCUT=ocopenai
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode OpenAI GPT-5.5
DESCRIPTION=OpenCode avec OpenAI GPT-5.5 et small_model GPT-5.4 mini.
ORDER=210
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=OPENAI_API_KEY
OPENAI_API_KEY=PASTE_OPENAI_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"openai/gpt-5.5","small_model":"openai/gpt-5.4-mini","provider":{"openai":{"options":{"apiKey":"{env:OPENAI_API_KEY}","timeout":600000,"chunkTimeout":60000}}},"share":"manual"}
