PROFILE_ID=opencode-minimax-openrouter
SHORTCUT=ocminimax
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode MiniMax via OpenRouter
DESCRIPTION=Template MiniMax via OpenRouter. Remplace le model id par celui que tu veux utiliser.
ORDER=232
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=OPENROUTER_API_KEY
OPENROUTER_API_KEY=PASTE_OPENROUTER_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"openrouter/minimax/minimax-m3","small_model":"openrouter/minimax/minimax-m3","provider":{"openrouter":{"options":{"apiKey":"{env:OPENROUTER_API_KEY}","timeout":600000,"chunkTimeout":60000}}},"share":"manual"}
