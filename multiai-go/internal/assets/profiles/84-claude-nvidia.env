PROFILE_ID=claude-nvidia
SHORTCUT=nv-cc
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=NVIDIA GLM-5.2 gratuit (pont integre)
DESCRIPTION=GLM-5.2 gratuit via build.nvidia.com (~40 req/min). Pont Anthropic->OpenAI INTEGRE au binaire multiai: demarre et arrete automatiquement, aucun proxy externe a installer.
ORDER=84
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=NVIDIA_API_KEY
BRIDGE=anthropic-openai
BRIDGE_TARGET=https://integrate.api.nvidia.com/v1
BRIDGE_KEY_VAR=NVIDIA_API_KEY
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-nvidia
NVIDIA_API_KEY=PASTE_NVIDIA_API_KEY_HERE
ANTHROPIC_AUTH_TOKEN=%NVIDIA_API_KEY%
ANTHROPIC_MODEL=z-ai/glm-5.2
ANTHROPIC_DEFAULT_OPUS_MODEL=z-ai/glm-5.2
ANTHROPIC_DEFAULT_SONNET_MODEL=z-ai/glm-5.2
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-ai/deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-ai/deepseek-v4-flash
ANTHROPIC_API_KEY=
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
