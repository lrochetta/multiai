PROFILE_ID=opencode-kimi-direct
SHORTCUT=ockimi-direct
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode Kimi direct (Moonshot)
DESCRIPTION=OpenCode avec Kimi K2 via Moonshot (endpoint direct)
ORDER=242
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=MOONSHOT_API_KEY
MOONSHOT_API_KEY=PASTE_MOONSHOT_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"moonshot/kimi-k2","small_model":"moonshot/kimi-k2","provider":{"moonshot":{"npm":"@ai-sdk/openai-compatible","name":"Moonshot","options":{"baseURL":"https://api.moonshot.ai/v1","apiKey":"{env:MOONSHOT_API_KEY}","timeout":600000,"chunkTimeout":60000},"models":{"kimi-k2":{"name":"Kimi K2"}}}},"share":"manual"}
