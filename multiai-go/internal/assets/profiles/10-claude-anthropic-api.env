PROFILE_ID=claude-anthropic-api
SHORTCUT=ca
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=Anthropic API officielle
DESCRIPTION=Claude Code via cle API Anthropic officielle.
ORDER=20
