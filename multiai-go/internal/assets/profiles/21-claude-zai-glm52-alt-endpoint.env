PROFILE_ID=claude-zai-glm52-alt
SHORTCUT=cgalt
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=Z.ai GLM-5.2 endpoint alternatif
DESCRIPTION=Variante API coding/paas/v4 si ton compte Z.ai le demande.
ORDER=31
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=ANTHROPIC_API_KEY
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-zai-glm52-alt
ANTHROPIC_BASE_URL=https://api.z.ai/api/coding/paas/v4
ANTHROPIC_API_KEY=PASTE_ZAI_API_KEY_HERE
ANTHROPIC_MODEL=glm-5.2[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.7
CLAUDE_CODE_SUBAGENT_MODEL=glm-4.7
CLAUDE_CODE_AUTO_COMPACT_WINDOW=1000000
API_TIMEOUT_MS=3000000
CLAUDE_CODE_EFFORT_LEVEL=max
