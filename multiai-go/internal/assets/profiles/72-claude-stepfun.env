PROFILE_ID=claude-stepfun
SHORTCUT=stepfun
TOOL=claude
TOOL_LABEL=Claude Code
DISPLAY_NAME=StepFun Step Plan
DESCRIPTION=StepFun Step 3.7 Flash via endpoint Anthropic-compatible
ORDER=72
COMMAND=claude
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=STEPFUN_API_KEY
CLAUDE_CONFIG_DIR=%USERPROFILE%\.claude-stepfun
STEPFUN_API_KEY=PASTE_STEPFUN_API_KEY_HERE
ANTHROPIC_BASE_URL=https://api.stepfun.com/step_plan
ANTHROPIC_AUTH_TOKEN=%STEPFUN_API_KEY%
ANTHROPIC_MODEL=step-3.7-flash
ANTHROPIC_DEFAULT_OPUS_MODEL=step-3.7-flash
ANTHROPIC_DEFAULT_SONNET_MODEL=step-3.7-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=step-3.5-flash
CLAUDE_CODE_AUTO_COMPACT_WINDOW=200000
API_TIMEOUT_MS=600000
CLAUDE_CODE_EFFORT_LEVEL=max
