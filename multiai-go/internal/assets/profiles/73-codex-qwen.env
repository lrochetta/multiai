PROFILE_ID=codex-qwen
SHORTCUT=codex-qwen
TOOL=codex
TOOL_LABEL=Codex CLI
DISPLAY_NAME=Codex Qwen via DashScope
DESCRIPTION=Codex avec Qwen3-Coder via DashScope (Alibaba). Codex 2026 ignore OPENAI_BASE_URL: provider injecte par flags -c (API Responses DashScope, verifiee).
ORDER=110
COMMAND=codex
ARGS=-c model_provider=dashscope -c model=qwen3-coder -c model_providers.dashscope.name=DashScope -c model_providers.dashscope.base_url=https://dashscope-intl.aliyuncs.com/compatible-mode/v1 -c model_providers.dashscope.env_key=DASHSCOPE_API_KEY -c model_providers.dashscope.wire_api=responses
CLEAR_ENV=true
REQUIRED_SECRETS=DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=PASTE_DASHSCOPE_API_KEY_HERE
OPENAI_API_KEY=%DASHSCOPE_API_KEY%
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
