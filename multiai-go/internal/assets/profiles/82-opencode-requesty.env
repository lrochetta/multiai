PROFILE_ID=opencode-requesty
SHORTCUT=req-oc
TOOL=opencode
TOOL_LABEL=OpenCode
DISPLAY_NAME=OpenCode via Requesty
DESCRIPTION=OpenCode via gateway Requesty (fallback, cache, EU)
ORDER=245
COMMAND=opencode
ARGS=
CLEAR_ENV=true
REQUIRED_SECRETS=REQUESTY_API_KEY
REQUESTY_API_KEY=PASTE_REQUESTY_API_KEY_HERE
OPENCODE_CONFIG_CONTENT={"$schema":"https://opencode.ai/config.json","model":"requesty/default","small_model":"requesty/default","provider":{"requesty":{"npm":"@ai-sdk/openai-compatible","name":"Requesty","options":{"baseURL":"https://router.requesty.ai/v1","apiKey":"{env:REQUESTY_API_KEY}","timeout":600000,"chunkTimeout":60000}}},"share":"manual"}
