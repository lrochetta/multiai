{
  "name": "multiai",
  "version": "0.6.9",
  "description": "Route multiple AI CLIs (Claude Code, Codex, OpenCode) with isolated env profiles — native Go binary, SHA256-verified download",
  "keywords": [
    "ai",
    "cli",
    "claude",
    "codex",
    "opencode",
    "router",
    "anthropic",
    "deepseek",
    "openrouter"
  ],
  "license": "MIT",
  "author": {
    "name": "Laurent Rochetta",
    "url": "https://follow.ovh/bio/laurent"
  },
  "homepage": "https://rochetta.fr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lrochetta/multiai.git"
  },
  "bin": {
    "multiai": "bin/multiai.js"
  },
  "files": [
    "bin/multiai.js",
    "lib/windows-path.js",
    "lib/version-probe.js",
    "scripts/ensure-user-path.ps1",
    "scripts/version-probe-controller.ps1",
    "install.js",
    "scan-secrets.js",
    "README.md"
  ],
  "scripts": {
    "test": "node --test install.test.js release-preflight.test.js bin/multiai.test.js lib/windows-path.test.js lib/version-probe.test.js",
    "postinstall": "node install.js",
    "prepublishOnly": "npm test && node scan-secrets.js && node release-preflight.js"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
