# Maintainer: Laurent Rochetta <laurent@rochetta.fr>
#
# Source-build AUR package.
#
# Before publishing to the AUR:
#   1. Pin the real tarball checksum:
#        multiai-go/scripts/update-aur-checksums.sh <version>
#      (e.g. ./multiai-go/scripts/update-aur-checksums.sh 0.5.0)
#   2. The script also regenerates .SRCINFO.
#   3. Then push the AUR repo:
#        cd packaging/aur
#        git add PKGBUILD .SRCINFO
#        git commit -m "upstream v<version>"
#        git push
#
# 'SKIP' is the development value — never push SKIP to the AUR.

pkgname=multiai
pkgver=0.7.0
pkgrel=1
pkgdesc="Route multiple AI CLIs (Claude Code, Codex, OpenCode) with isolated env profiles"
arch=('x86_64' 'aarch64')
url="https://rochetta.fr"
license=('MIT')
makedepends=('go')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/lrochetta/multiai/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('219448bf86f130c4ee10b9013e479c685f105e21bd343b75530ba429582b59d6')

# The GitHub repository is a monorepo: the Go module lives in multiai-go/.
_moddir="${pkgname}-${pkgver}/multiai-go"

build() {
    cd "${srcdir}/${_moddir}"
    export CGO_ENABLED=0
    go build -trimpath -ldflags "-s -w -X main.version=${pkgver}" -o multiai ./cmd/multiai/
}

check() {
    cd "${srcdir}/${_moddir}"
    go test ./...
}

package() {
    cd "${srcdir}/${_moddir}"
    install -Dm755 multiai "${pkgdir}/usr/bin/multiai"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    # LICENSE is in the monorepo root, one level above _moddir
    if [ -f "${srcdir}/${pkgname}-${pkgver}/LICENSE" ]; then
        install -Dm644 "${srcdir}/${pkgname}-${pkgver}/LICENSE" \
            "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    fi
}
